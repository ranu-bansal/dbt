03:06:01.701444 [debug] [Thread-1 (]: On model.quince.sales_by_brand_country: /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "quince", "target_name": "dev", "node_id": "model.quince.sales_by_brand_country"} */

    
  
    
    

    create temporary table
      "sales_by_brand_country__dbt_tmp20260322030601691438"
  
    as (
      

SELECT
  p.brand_id,
  p.brand_name,
  TRIM(UPPER(o.country))      AS country,
  CAST(o.order_date AS DATE)   AS order_date,
  COUNT(DISTINCT o.order_id)   AS total_orders,
  SUM(i.quantity)              AS total_units,
  SUM(i.subtotal)              AS total_revenue,
  SUM(i.subtotal)              AS total_revenue_tmp
FROM "warehouse"."main_staging"."stg_orders" o
JOIN "warehouse"."raw"."order_items" i ON o.order_id = i.order_id
JOIN "warehouse"."raw"."products" p ON i.product_id = p.product_id
WHERE 
LOWER(TRIM(o.status)) NOT IN ('cancelled')


  AND CAST(o.order_date AS DATE) >= (
    SELECT COALESCE(MAX(order_date), DATE '1900-01-01') FROM "warehouse"."main_marts"."sales_by_brand_country"
  )
  
GROUP BY p.brand_id, p.brand_name, o.country, o.order_date
    );
  
  
  
